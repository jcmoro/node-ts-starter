NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---------- Database ----------
# Si DATABASE_URL está set → se usa Postgres. Si no → SQLite en DATABASE_PATH.

# Opción 1 — SQLite (sin setup, default):
DATABASE_PATH=:memory:
# DATABASE_PATH=./data.db        # persistir en archivo

# Opción 2 — Supabase Session Pooler (recomendado, funciona con cualquier red):
# Dashboard → Settings → Database → Connection string → tab "Session pooler"
# Hostname y username distintos a la conexión directa.
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Opción 3 — Supabase Direct Connection (solo si tu red soporta IPv6):
# El hostname db.[PROJECT-REF].supabase.co solo expone IPv6. En ISPs domésticos
# sin IPv6 da ENOTFOUND. Si te falla, vuelve a la opción 2.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Opción 4 — Supabase Transaction Pooler (solo serverless; NO usar aquí):
# Puerto 6543. No soporta prepared statements; requeriría cambiar
# `prepare: true` → `prepare: false` en src/db/postgres.ts.
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Opción 5 — Postgres local en docker (lo levanta docker-compose.dev.yml):
# DATABASE_URL=postgresql://postgres:postgres@localhost:55432/app

# ---------- OpenTelemetry ----------
# Por defecto el SDK arranca con ConsoleSpanExporter (dump a stdout). Para
# silenciarlo en dev, descomenta la primera línea. Para exportar a un
# collector real (Jaeger, Tempo, Honeycomb...), pon el endpoint.
# OTEL_SDK_DISABLED=true
# OTEL_SERVICE_NAME=node-ts-starter-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ---------- Test-only ----------
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:55432/app
