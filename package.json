{
  "name": "node-ts-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node --watch --experimental-strip-types --experimental-sqlite --env-file-if-exists=.env --import ./src/tracing.ts src/index.ts",
    "start": "node --experimental-strip-types --experimental-sqlite --env-file-if-exists=.env --import ./src/tracing.ts src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types --experimental-sqlite 'src/**/*.test.ts'",
    "test:watch": "node --test --watch --experimental-strip-types --experimental-sqlite 'src/**/*.test.ts'",
    "test:coverage": "node --test --experimental-test-coverage --experimental-strip-types --experimental-sqlite 'src/**/*.test.ts'",
    "migrate": "node --experimental-strip-types --env-file-if-exists=.env src/db/cli.ts migrate",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "hono": "^4.6.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.0"
  }
}
